# Backend data & uploads
# KEEP brand-context assets in the repo (avatars, products, clothing, backgrounds,
# moodboards, logos) so a clone ships with the full brand kit ready to use.
# IGNORE only the heavy generated outputs (renders, ~GBs) and transient/runtime files.
backend/data/renders/*
backend/data/generations.json
backend/data/ig-imports/*
backend/tmp/*

# Project specific
.agent/
.agents/
.interface-design/
skills-lock.json
videoref/

# Keep empty directories with .gitkeep
!backend/data/renders/.gitkeep
!backend/tmp/.gitkeep

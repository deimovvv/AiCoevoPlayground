# Coevo Studio — backend environment
# Copy to backend/.env and fill in your keys. NEVER commit the real .env.

# ── Required ────────────────────────────────────────────────
GEMINI_API_KEY=        # Google AI Studio — scripts, chat, prompt assembly, agent
FAL_KEY=               # fal.ai — Nano Banana 2, Kling, Seedance (image + video)
ELEVENLABS_API_KEY=    # ElevenLabs — TTS, Voice Design, voice cloning

# ── Optional ────────────────────────────────────────────────
HEYGEN_API_KEY=        # HeyGen Avatar 4 — talking-photo lip-sync (UGC)
BEEBLE_API_KEY=        # Beeble SwitchX — Video Swap tool
BEEBLE_API_BASE=       # Beeble API base URL (only if non-default)
APIFY_API_KEY=         # Apify — Instagram scraping for Content Analyzer imports
VOICE_ID_ELIAS=        # Optional default ElevenLabs voice id
